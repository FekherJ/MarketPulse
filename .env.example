PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketpulse
DB_USER=postgres
DB_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379

COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Enable the local scheduled ingestion job.
# Set to true for local development so the API process runs node-cron.
# Set to false in cloud/API-only deployments if ingestion is triggered separately
# by an external scheduler such as AWS EventBridge or an ECS scheduled task.
ENABLE_INGESTION_JOB=true
FETCH_INTERVAL_SECONDS=60


ALERT_VARIATION_THRESHOLD_PCT=3.0
